rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function role() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return request.auth != null && role() == 'admin';
    }

    function isRegisterer() {
      return request.auth != null && role() == 'registerer';
    }

    function isStaff() {
      return isAdmin() || isRegisterer();
    }

    function hasAnyAssetDescription(record) {
      return record.rows is list
        && record.rows.size() > 0
        && record.rows[0].assetDescription is string
        && record.rows[0].assetDescription.size() > 0;
    }

    match /warehouseEntries/{entryId} {
      allow read: if request.auth != null;
      allow create: if isStaff()
        && request.resource.data.keys().hasAll(['assetType','quantity','owner','warehouseNo','manager','date','inspection','sNo'])
        && request.resource.data.assetType is string
        && request.resource.data.assetType.size() > 0;
      allow update, delete: if isAdmin();
    }

    match /fixedAssetRecords/{recordId} {
      allow read: if request.auth != null;
      allow create: if isStaff()
        && request.resource.data.header is map
        && request.resource.data.header.employeeName is string
        && request.resource.data.header.employeeName.size() > 0
        && request.resource.data.header.department is string
        && request.resource.data.header.department.size() > 0
        && hasAnyAssetDescription(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if false;
    }
  }
}
